{
  "name": "{{PROJECT_SLUG}}",
  "version": "{{MSC_VERSION}}",
  "description": "{{PROJECT_NAME}}",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/prebuild-static.mjs && node scripts/dev-fresh.mjs",
    "build": "node scripts/prebuild-static.mjs && next build",
    "start": "next start -p {{PORT}}",
    "seed": "cross-env ENABLE_PAYLOAD=true tsx scripts/seed-demo-data.mjs",
    "seed:fresh": "cross-env ENABLE_PAYLOAD=true tsx scripts/seed-demo-data.mjs --fresh",
    "postinstall": "node scripts/postinstall.mjs",
    "deploy:prep": "bash scripts/deploy-prep.sh"
  },
  "dependencies": {
    "next": "15.4.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "optionalDependencies": {
    "payload": "^3.0.0",
    "@payloadcms/db-sqlite": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "sharp": "^0.33.5",
    "graphql": "^16.8.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "typescript": "^5.0.0",
    "tsx": "^4.19.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
