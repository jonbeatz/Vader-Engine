# Static production (Hostinger): leave false — no database required
ENABLE_PAYLOAD=false

# Local CMS editing: set true and configure secrets below
# ENABLE_PAYLOAD=true
# PAYLOAD_SECRET=CHANGE_ME_PAYLOAD_SECRET
# DATABASE_URI=file:./database/payload.db
# DATABASE_URL=file:./database/payload.db
# PAYLOAD_DB_PUSH=true

MSC_PUBLIC_ORIGIN=http://127.0.0.1:{{PORT}}
PORT={{PORT}}
