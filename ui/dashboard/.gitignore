# ui/dashboard hygiene
# Keep the repository lean: only the hardened Tailwind-v3 files are tracked.

# dependencies / build artifacts
node_modules/
.next/
out/
build/
.dist/

# env files
.env*

# Ignore the rest of the v0-export dump (tracked files are explicitly allow-listed below)
*

# Re-include the hardened dashboard surface
!.gitignore
!app/
!app/globals.css
!app/layout.tsx
!components.json
!next.config.mjs
!package.json
!package-lock.json
!postcss.config.mjs
!tailwind.config.ts
!components/
!components/ui/
!components/ui/button.tsx
!components/ui/card.tsx
!components/ui/command.tsx
!components/ui/dialog.tsx
!components/ui/input.tsx