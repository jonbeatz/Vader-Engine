# ==============================================================================
# MASTER LOCAL OVERRIDES (REFERENCE ONLY)
# ==============================================================================
# Location: .cursor/env/master.env.local.example
# Purpose:  Template for what belongs in a project's `.env.local` (gitignored).
#           NOT wired into Vader-Engine — copy selected keys per project as needed.
#
# ------------------------------------------------------------------------------
# 📁 RELATED FILES
# ------------------------------------------------------------------------------
# .cursor/env/
# ├── master.env.example        ← full key contract (placeholders)
# └── master.env.local.example  ← YOU ARE HERE
#
# Pattern from consumer SMTP backup [P3]:
#   • Dev origin must match the browser tab (verification links, cookies).
#   • Use ONE of 127.0.0.1 OR localhost consistently — do not mix.
#     ✅ Good: http://127.0.0.1:3000
#     ✅ Good: http://localhost:3000
#     ❌ Bad:  Mixing both in different env files
#   • Live SMTP passwords belong here, never in .env.example or Git.
#   • Do not paste this file verbatim onto a production server.
#
# Quick start: copy this file → project .env.local → fill real values only here.
# NEVER commit .env.local. See master.env.example for the full key contract.
# ==============================================================================

# --- Local dev origin (override production-shaped NEXT_PUBLIC_SITE_URL) ---
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
# [P2] If the consumer app reads this key instead:
NEXT_PUBLIC_SERVER_URL=http://127.0.0.1:3000

# --- Dev-only shortcuts (never enable on production) ---
DEV_BYPASS_ENABLED=true

# --- Required secrets (generate fresh per project) ---
PAYLOAD_SECRET=replace-with-long-random-secret-generated-locally
# MSC_AUTH_SECRET=replace-if-project-uses-it

# --- LiteLLM / Cursor AI proxy (Vader Engine local dev) ---
# MSC_LITELLM_MASTER_KEY=your_litellm_master_key_local_only
# GOOGLE_APPLICATION_CREDENTIALS=config/gcp-service-account.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# --- MCP / integration keys you actively use (uncomment and fill) ---
# GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat
# TAVILY_API_KEY=your_tavily_api_key
# FIRECRAWL_API_KEY=your_firecrawl_api_key
# RESEND_API_KEY=your_resend_api_key
# VERCEL_API_TOKEN=your_vercel_api_token

# --- Spacemail SMTP (local verification / welcome email testing) [P3] ---
MSC_STUDIO_OUTGOING_HOST=mail.spacemail.com
MSC_STUDIO_OUTGOING_PORT=465
MSC_STUDIO_OUTGOING_SSL=true
MSC_STUDIO_OUTGOING_USER=your-full-mailbox@yourdomain.com
MSC_STUDIO_OUTGOING_PASS=your-app-password-from-mail-dashboard
# MSC_STUDIO_OUTGOING_FROM="MSC Studio <your-full-mailbox@yourdomain.com>"

# --- Optional machine-specific paths ---
# MSC_BACKUP_ROOT=G:/Cursor_Project_BackUpz/Vader-Engine

# ==============================================================================
