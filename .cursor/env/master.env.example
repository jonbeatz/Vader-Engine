# ==============================================================================
# MASTER ENVIRONMENT CONTRACT (REFERENCE ONLY)
# ==============================================================================
# Location: .cursor/env/master.env.example
# Purpose:  Personal reference vault — NOT wired into Vader-Engine runtime.
#           Do NOT copy to repo root unless you intentionally update .env.example.
#
# ------------------------------------------------------------------------------
# 📁 RELATED FILES
# ------------------------------------------------------------------------------
# .cursor/env/
# ├── master.env.example        ← YOU ARE HERE
# └── master.env.local.example  ← local overrides template
#
# ------------------------------------------------------------------------------
# 🚀 QUICK START FOR A NEW PROJECT
# ------------------------------------------------------------------------------
# 1. Copy master.env.example → your project's .env.example
# 2. Copy master.env.local.example → your project's .env.local
# 3. Fill in real values in .env.local only
# 4. NEVER commit .env.local
#
# Vader-Engine load order (when using repo root files):
#   .env.local (live) → .env.example (contract, fills gaps via msc-load-env.mjs)
#
# ------------------------------------------------------------------------------
# VISUAL LEGEND (source tags on keys below)
# ------------------------------------------------------------------------------
# | Tag   | Source                              |
# |-------|-------------------------------------|
# | [VE6] | Vader Engine boilerplate (primary)  |
# | [P2]  | Consumer Payload site               |
# | [P3]  | Consumer SMTP / auth patterns       |
#
# Built from historical backups (optional: env/backups/N/):
#   [VE6]  Vader Engine boilerplate
#   [P2]   Consumer Payload site
#   [P3]   Consumer SMTP / auth patterns
#
# ------------------------------------------------------------------------------
# ⚠️ DANGER ZONE — NEVER COMMIT THESE
# ------------------------------------------------------------------------------
# - Any key with SECRET, PASSWORD, TOKEN, or KEY (live values)
# - DEV_BYPASS_ENABLED=true (dev only — never on production)
# - Live SMTP credentials (MSC_STUDIO_OUTGOING_USER / _PASS)
# - API keys for paid services (Resend, Firecrawl, Tavily, Vercel, etc.)
# ==============================================================================

# ------------------------------------------------------------------------------
# APPLICATION PATHS & CORE METADATA
# ------------------------------------------------------------------------------
# [VE6]
NODE_ENV=development
MSC_PUBLIC_ORIGIN=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com
PORT=3000
# 👇 Optional: custom dev server port — PORT=4000
# Template vader-site default: PORT=3003 (see templates/full-stack/vader-site/.env.example)

# [P2] Alternate public URL keys used by some consumer Payload apps.
# Some stacks read NEXT_PUBLIC_SERVER_URL instead of (or alongside) NEXT_PUBLIC_SITE_URL.
# Local dev: set to http://localhost:3000 or http://127.0.0.1:3000 (pick one consistently).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# [P2] Production-only on cPanel/Spaceship Node — Payload, verification links, admin emails.
# Takes precedence over NEXT_PUBLIC_SERVER_URL on live hosts. Leave commented for local dev.
# PAYLOAD_PUBLIC_SERVER_URL=https://your-production-domain.com

# [P2] Final fallback when NEXT_PUBLIC_* and PAYLOAD_PUBLIC_* are both unset in app code.
# MSC_CANONICAL_SITE_ORIGIN=https://your-production-domain.com

# ------------------------------------------------------------------------------
# GITHUB CLI SYNC (optional — npm run msc:github:sync)
# ------------------------------------------------------------------------------
# [VE6]
# MSC_GITHUB_DESCRIPTION=Cursor-native boilerplate — 60-point grader…
# MSC_GITHUB_HOMEPAGE=https://vaderlabz.com

# ------------------------------------------------------------------------------
# DATABASE (Payload / SQLite default — swap for MySQL/Postgres in production)
# ------------------------------------------------------------------------------
# [VE6] Vader Engine default path — consumer projects may use file:./payload.sqlite [P2][P3]
DATABASE_URI=file:./data/payload.sqlite
DATABASE_URL=file:./data/payload.sqlite
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/db_name
# DATABASE_AUTH_TOKEN=

# ------------------------------------------------------------------------------
# SECURITY & AUTH
# ------------------------------------------------------------------------------
# [VE6]
PAYLOAD_SECRET=your_long_random_alphanumeric_payload_secret_string
MSC_AUTH_SECRET=your_long_random_alphanumeric_auth_secret_string
PAYLOAD_CSRF_EXTRA_ORIGINS=

# [P3] Dev-only auth bypass — set true in .env.local only, never on production.
# [P3] Production .env.example default: false
DEV_BYPASS_ENABLED=false

# ------------------------------------------------------------------------------
# CONSUMER SITE FEATURES (booking, contact — not all Vader-Engine templates use these)
# ------------------------------------------------------------------------------
# [P2] External "Schedule a call" URL (contact section). Falls back to placeholder if unset.
# NEXT_PUBLIC_SCHEDULE_CALL_URL=https://example.com/schedule

# [P2] Booking integration — `payload` = same-origin /api/bookings; or WordPress REST URL:
NEXT_PUBLIC_MSC_BOOKING_URL=payload
# NEXT_PUBLIC_MSC_BOOKING_URL=https://example.com/wp-json/msc/v1/booking-request

# ------------------------------------------------------------------------------
# LOCAL SCRIPT GATES (web dev port 3000 — see scripts/msc-*.mjs)
# ------------------------------------------------------------------------------
# [VE6]
MSC_DEV_PORT=3000
MSC_DASHBOARD_PORT=3010
MSC_DASHBOARD_HOST=127.0.0.1
# MSC_DASHBOARD_API_TOKEN=your_dashboard_api_token
MSC_SMOKE_HOST=127.0.0.1
MSC_SMOKE_PATHS=/,/api/health,/admin
MSC_SMOKE_TIMEOUT_MS=20000
# MSC_SMOKE_STRICT=1
# Set to 1 to fail smoke when no dev server is listening (default: template bypass exit 0)

# ------------------------------------------------------------------------------
# BACKUP (scripts/msc-backup.mjs — npm run msc:backup)
# ------------------------------------------------------------------------------
# [VE6]
# MSC_BACKUP_ROOT=G:/Cursor_Project_BackUpz/Vader-Engine

# ------------------------------------------------------------------------------
# AI PROXY (LiteLLM + Vertex — ports 4000/8000, see .cursor/docs/local-ai-proxy-setup.md)
# ------------------------------------------------------------------------------
# [VE6]
MSC_LITELLM_PORT=4000
MSC_LITELLM_START_NGROK=0
# MSC_NGROK_BIN=google-api/ngrok.exe
# NGROK_AUTHTOKEN=your_ngrok_authtoken
# MSC_LITELLM_BASE_URL=http://127.0.0.1:4000
LITELLM_DROP_PARAMS=true
GOOGLE_APPLICATION_CREDENTIALS=config/gcp-service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
MSC_LITELLM_MASTER_KEY=your_litellm_master_key_local_only
# MSC_LITELLM_DATABASE_URL=postgresql://user:password@127.0.0.1:5432/litellm

# ------------------------------------------------------------------------------
# MCP & INTEGRATION API KEYS (mirror into Cursor MCP env — placeholders only in Git mcp.json)
# shadcn + context7 MCP: no keys required here (see .cursor/mcp.json)
# ------------------------------------------------------------------------------
# [VE6] GitHub — PRs, releases, issues (@modelcontextprotocol/server-github)
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat

# [VE6] Web search — Tavily MCP
TAVILY_API_KEY=your_tavily_api_key

# [VE6] Untitled UI PRO — untitledui-mcp (global ~/.cursor/mcp.json + Cursor MCP env)
UNTITLEDUI_LICENSE_KEY=your_untitledui_license_key

# [VE6] Scrape / crawl — Firecrawl MCP
FIRECRAWL_API_KEY=your_firecrawl_api_key

# [VE6][P2] Email — Resend MCP + transactional mail in Node stacks
RESEND_API_KEY=your_resend_api_key

# [VE6] Deploy — Vercel MCP (optional; often configured in global ~/.cursor/mcp.json)
VERCEL_API_TOKEN=your_vercel_api_token

# [VE6] API testing — Postman MCP
POSTMAN_API_KEY=your_postman_api_key

# [VE6] WordPress REST — @automattic/mcp-wordpress-remote (local-wp sites)
WP_API_URL=https://your-local-site.test/wp-json/mcp/mcp-adapter-default-server
WP_API_USERNAME=your_wp_admin_user
WP_API_PASSWORD=your_wp_application_password
WORDPRESS_APP_PASSWORD=your_wp_application_password

# [VE6] InstaWP stack (optional)
INSTAWP_API_URL=
INSTAWP_APP_PASSWORD=
ELEMENTOR_LICENCE_KEY=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# [VE6] Google Workspace MCP (paths only — keys live in JSON files under config/)
GOOGLE_CREDENTIALS_PATH=config/gcp-service-account.json
GOOGLE_TOKEN_PATH=config/google-oauth-token.json

# [VE6] Payload CMS MCP (when using remote API mode)
PAYLOAD_API_URL=https://your-domain.com/api
PAYLOAD_API_KEY=your_payload_api_key

# [VE6] Neon serverless Postgres MCP (OAuth via browser on first connect)
# NEON_API_KEY=

# [VE6] Stream / media (MSC-Core-Pro patterns — consumer WordPress/plugin)
MSC_BUNNY_API_KEY=
MSC_BUNNY_LIBRARY_ID=
MSC_BUNNY_CDN_HOST=
MSC_PRESTO_LICENSE_KEY=
MSC_YOUTUBE_API_KEY=

# ------------------------------------------------------------------------------
# OUTBOUND MAIL (PHP msc_send_mail, Node nodemailer, or Brevo/Fluent)
# ------------------------------------------------------------------------------
# [VE6] Brevo / Fluent SMTP (WordPress or JSON config patterns)
BREVO_API_KEY=YOUR_BREVO_API_KEY_HERE
FLUENT_SMTP_CONFIG=YOUR_FLUENT_SMTP_JSON_CONFIG_HERE

# [P3][VE6] Spaceship Spacemail / cPanel SMTP (nodemailer).
# On production cPanel: prefer Node.js Application Manager → Environment Variables.
# Local testing: copy live mailbox values into .env.local (see master.env.local.example).
MSC_STUDIO_OUTGOING_HOST=mail.spacemail.com
MSC_STUDIO_OUTGOING_PORT=465
MSC_STUDIO_OUTGOING_SSL=true
MSC_STUDIO_OUTGOING_USER=your-full-mailbox@yourdomain.com
MSC_STUDIO_OUTGOING_PASS=your-app-password-from-mail-dashboard
# MSC_STUDIO_OUTGOING_FROM="MSC Studio <noreply@yourdomain.com>"

# ------------------------------------------------------------------------------
# MULTI-STRATEGY MEDIA CONFIGURATION MATRIX
# ------------------------------------------------------------------------------
# [VE6] Select: local | multi-tenant | stream-cdn
MSC_MEDIA_STRATEGY=local

# [VE6] Image optimization controls
MSC_DISABLE_SHARP_COMPRESSION=false
MSC_FORCE_WEBP_CONVERSION=true
MSC_WEBP_QUALITY=82
MSC_MEDIA_THUMBNAIL_WIDTH=400
MSC_MEDIA_THUMBNAIL_HEIGHT=300

# [VE6] Path roots (strategy-specific)
MSC_MEDIA_LOCAL_DIR=media
MSC_MEDIA_TENANT_ROOT=uploads

# [VE6] Stream CDN strategy (when MSC_MEDIA_STRATEGY=stream-cdn)
MSC_CDN_PROVIDER=s3
MSC_CDN_BUCKET=your-bucket-name
MSC_CDN_PREFIX=media
MSC_CDN_PUBLIC_BASE_URL=https://cdn.your-domain.com
MSC_CDN_LOCAL_CACHE_DIR=media
MSC_CDN_SIGNED_UPLOAD=false
MSC_CDN_ADAPTER=payload-cloud-storage

# [VE6] Legacy alias — same as MSC_MEDIA_STRATEGY=multi-tenant
# MSC_MEDIA_MODE=multi-tenant

# [VE6] Media sync utility (scripts/msc-core-sync.mjs)
MSC_MEDIA_SYNC_DRY_RUN=false

# ------------------------------------------------------------------------------
# PAYLOAD / SQLITE STRATEGY (see .cursor/docs/ecosystem-options-matrix.md)
# ------------------------------------------------------------------------------
# [VE6]
PAYLOAD_DB_PUSH=false
PAYLOAD_SQLITE_PUSH=
PAYLOAD_MIGRATING=false
MSC_SQLITE_REPAIR_MANIFEST=config/sqlite-repair-manifest.example.json
MSC_SQLITE_REPAIR_DRY_RUN=true
MSC_SQLITE_WAL_PURGE=false
MSC_RESCUE_EMAIL=
MSC_RESCUE_PASSWORD=
MSC_RESCUE_ROLE=admin

# ------------------------------------------------------------------------------
# RUNTIME RECOVERY & BUILD GATES
# ------------------------------------------------------------------------------
# [VE6]
MSC_CLEAN_NEXT=false
MSC_DEV_RECOVER_CLEAN=false
MSC_VERIFY_NEXT_RUN_BUILD=false
MSC_SMOKE_RUN_TYPECHECK=false
MSC_SMOKE_RUN_MIGRATIONS=
MSC_REPAIR_AST=false

# ------------------------------------------------------------------------------
# UI SHIELD EXTENSIONS (glass, forms, motion — ui/msc-shield-extensions.css)
# ------------------------------------------------------------------------------
# [VE6]
MSC_SHIELD_EXTENSIONS=false

# --- Docker Services (optional — uncomment if using docker-compose.yml) ---
# [VE6]
# DOCKER_POSTGRES_URL=postgresql://msc_user:msc_password@localhost:5432/msc_db
# DOCKER_REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# PAYLOAD / MEDIA OPTIONS
# ------------------------------------------------------------------------------
# [VE6][P2] cPanel / shared hosts: set true when sharp native binaries are unavailable.
PAYLOAD_DISABLE_SHARP=false

# ------------------------------------------------------------------------------
# HOSTING (Spaceship / cPanel — see .cursor/docs/spaceship-node-deployment.md)
# ------------------------------------------------------------------------------
# [VE6]
SPACESHIP_APP_DIR=/home/username/public_html/node-app
SPACESHIP_NODE_VENV_ACTIVATE=source ~/nodevenv/your-domain.com/20/bin/activate

# ==============================================================================
# KEY INDEX (quick lookup — which backup introduced each consumer-only key)
# ==============================================================================
# NEXT_PUBLIC_SERVER_URL      [P2]  Consumer Payload public URL (dev)
# PAYLOAD_PUBLIC_SERVER_URL   [P2]  Production Payload origin (live host only)
# MSC_CANONICAL_SITE_ORIGIN   [P2]  App fallback when other URL keys unset
# NEXT_PUBLIC_SCHEDULE_CALL_URL [P2]  External calendar / contact CTA
# NEXT_PUBLIC_MSC_BOOKING_URL [P2]  Booking backend target
# DEV_BYPASS_ENABLED          [P3]  Local dev auth bypass (never production)
# MSC_STUDIO_OUTGOING_*       [P3]  Spacemail / nodemailer SMTP block
# MSC_LITELLM_* / MCP keys    [VE6] Vader Engine boilerplate only
# MSC_MEDIA_* / MSC_CDN_*     [VE6] Vader Engine media matrix
# ==============================================================================

# ==============================================================================
# Version: 1.0.0 | Last Updated: 2026-05-29
# Maintainer: Jon Beatz
# ==============================================================================
