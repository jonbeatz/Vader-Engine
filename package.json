{
  "name": "msc-universal-boilerplate",
  "version": "2.4.0",
  "description": "Cursor-native full-stack boilerplate with a 60-point self-grader, template scaffolding CLI, isolated Next.js / Payload / WordPress sandboxes, Vader Protocol UI shield, Biome linting, and MCP-ready agent workflows",
  "type": "module",
  "main": "core/index.mjs",
  "scripts": {
    "prepare": "husky",
    "build": "cd examples/nextjs-minimal && npm install && npm run build",
    "start": "cd examples/nextjs-minimal && npm run start -- -p $PORT",
    "bootstrap": "npm run msc:kill-dev-port && node scripts/quickstart.mjs",
    "msc:health": "node scripts/health.mjs",
    "msc:health:json": "node scripts/health.mjs --json",
    "msc:update": "node scripts/msc-update.mjs",
    "msc:forge": "node scripts/msc-forge.mjs",
    "msc:quickstart": "node scripts/quickstart.mjs",
    "msc:validate-env": "node scripts/validate-env.mjs",
    "msc:kill-dev-port": "node scripts/msc-kill-all-dev-ports.mjs",
    "msc:test": "cd examples/nextjs-minimal && npm run test",
    "msc:test:watch": "cd examples/nextjs-minimal && npm run test:watch",
    "msc:dev:example": "cd examples/nextjs-minimal && npm run dev",
    "msc:dev:payload": "cd examples/nextjs-payload && npm run dev",
    "verify:mcp": "node scripts/msc-verify-mcp.mjs",
    "verify:mcp:probe": "node scripts/msc-verify-mcp.mjs --probe",
    "verify:local": "node scripts/msc-local-http-smoke.mjs",
    "verify:next:safe": "node scripts/msc-verify-next-safe.mjs",
    "msc:kill": "node scripts/msc-kill-dev-port.mjs",
    "msc:smoke": "node scripts/msc-local-http-smoke.mjs",
    "start-project:smoke": "node scripts/msc-start-project-smoke.mjs",
    "start-project": "npm run start-project:smoke",
    "end-project": "npm run msc:kill -- 3000 && npm run msc:smoke -- 3000",
    "media:sync": "node scripts/msc-core-sync.mjs",
    "dev:recover": "node scripts/msc-dev-recover.mjs",
    "clean:next": "node scripts/msc-clean-next-cache.mjs --force",
    "repair:sqlite": "node scripts/msc-sqlite-repair.mjs",
    "repair:ast": "node scripts/repair/msc-fix-suspense.mjs",
    "db:wal-purge": "node scripts/msc-sqlite-wal-purge.mjs --force",
    "db:rescue-admin": "node scripts/msc-rescue-admin.mjs",
    "check:all": "node scripts/msc-verify-mcp.mjs --probe && node scripts/msc-local-http-smoke.mjs --no-strict",
    "test:integration": "node --experimental-strip-types tests/msc-integration-stub.test.ts",
    "log": "node scripts/msc-log-event.mjs",
    "inventory": "node scripts/msc-generate-inventory.mjs",
    "grade": "node scripts/msc-grade-boilerplate.mjs",
    "msc:lint": "biome check .",
    "msc:lint:fix": "biome check --write .",
    "msc:format": "biome format --write .",
    "msc:test:root": "vitest run",
    "msc:test:all": "vitest run && npm test --prefix examples/nextjs-minimal",
    "msc:test:grader": "vitest run scripts/__tests__/msc-grade-boilerplate.test.mjs",
    "msc:onboard": "node scripts/msc-onboarding.mjs",
    "msc:shield:audit": "node scripts/msc-shield-audit.mjs",
    "msc:ingest": "node scripts/msc-ingest.mjs",
    "msc:new:component": "node scripts/msc-new-component.mjs",
    "msc:template": "node tools/msc-cli/cli.mjs",
    "msc:mock:media": "node scripts/msc-mock-media.mjs",
    "msc:ensure-lockfiles": "node scripts/msc-ensure-lockfiles.mjs",
    "msc:e2e:install": "playwright install --with-deps chromium firefox",
    "msc:e2e": "playwright test --config e2e/playwright.config.ts"
  },
  "lint-staged": {
    "*.{js,mjs,ts,tsx,jsx}": [
      "biome check --write"
    ],
    "!(package-lock)*.{json,css}": [
      "biome format --write"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonbeatz/Boilerplate-v2.git"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.0.0 <25.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.52.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "vitest": "^4.1.7"
  }
}
